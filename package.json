{
  "name": "calendary-whatsapp",
  "version": "1.0.0",
  "description": "Sistema de agendamiento escolar via WhatsApp",
  "main": "src/app.js",
  "type": "module",
  "packageManager": "pnpm@10.5.2",
  "scripts": {
    "start": "node ./src/app.js",
    "dev": "nodemon ./src/app.js"
  },
  "keywords": [
    "whatsapp",
    "chatbot",
    "agendamiento"
  ],
  "dependencies": {
    "@builderbot/bot": "1.4.1",
    "@builderbot/provider-baileys": "1.4.1",
    "dotenv": "^17.4.2",
    "google-auth-library": "^10.6.2",
    "googleapis": "^172.0.0",
    "groq-sdk": "^1.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "overrides": {
    "axios": "0.31.1",
    "jimp": "1.6.1",
    "music-metadata": "11.12.3",
    "protobufjs": "7.6.1",
    "sharp": "0.33.3"
  },
  "pnpm": {
    "overrides": {
      "axios": "0.31.1",
      "music-metadata": "11.12.3",
      "protobufjs": "7.6.1"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "jimp": "1.6.1",
        "sharp": "0.33.3"
      }
    },
    "onlyBuiltDependencies": [
      "baileys",
      "protobufjs",
      "sharp"
    ]
  },
  "author": "",
  "license": "ISC"
}
